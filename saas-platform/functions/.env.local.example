# billing Edge Functions のローカル env（コピーして .env.local を作る・コミットしない）。
# 使い方: cp saas-platform/functions/.env.local.example saas-platform/functions/.env.local → 値を埋める → pnpm saas:functions:serve

# Stripe（test モード）。ダッシュボード → Developers → API keys。
STRIPE_SECRET_KEY=sk_test_xxx
# `stripe listen --forward-to localhost:54321/functions/v1/billing-webhook` が表示する whsec_...
STRIPE_WEBHOOK_SECRET=whsec_xxx

# レシート署名鍵（node scripts/gen-receipt-key.mjs の出力2行をそのまま貼る）。
RECEIPT_SIGNING_KEY={"kty":"OKP",...}
RECEIPT_PUBLIC_KEY={"kty":"OKP",...}

# 製品ごとの success/cancel URL の origin 允許リスト（本番は config の saas.billing.allowed_origins 由来）。
BILLING_ALLOWED_ORIGINS={"demo-app":["http://localhost:3000"]}

# ローカル DB 直結（serve のデフォルト注入を上書きしたい場合のみ。通常は CLI が自動注入）。
# SUPABASE_DB_URL=postgres://postgres:postgres@127.0.0.1:55322/postgres?sslmode=disable
