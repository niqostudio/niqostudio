---
import { CTA } from '../../config/site';
import Button from '../ui/Button.astro';
import Jp from '../ui/Jp.astro';

// 副 CTA（サービス導線）は /services 上では自己参照になるため出さない。
const path = Astro.url.pathname;
const showServicesLink = !(path === '/services' || path.startsWith('/services/'));
---

<section class="border-t border-border">
  <div class="max-w-page mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-2xl font-semibold tracking-tight">{CTA.heading}</h2>
    <p class="text-muted mt-3 max-w-xl mx-auto"><Jp text={CTA.body} /></p>
    <div class="flex flex-wrap gap-4 justify-center mt-8">
      <Button href="/contact">無料相談する</Button>
      {showServicesLink && <Button href="/services" variant="secondary">サービスを見る</Button>}
    </div>
  </div>
</section>
