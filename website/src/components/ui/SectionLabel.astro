---
// 詳細ページのセクションラベル（mono 小見出し）。先頭の緑ティックでブランド色を通す。
// タイポは共有 .section-label（@niqostudio/ui）。サイズ・ティック・配置はここで持つ。
interface Props {
  as?: 'h2' | 'p' | 'dt';
  class?: string;
}
const { as: Tag = 'p', class: className } = Astro.props;
---

<Tag
  class:list={['section-label flex items-center gap-2 text-sm', className]}
>
  <span class="inline-block h-3.5 w-0.5 bg-accent" aria-hidden="true"></span>
  <slot />
</Tag>
