---
// タグ/チップ（<ul> 内の <li> として使う）。形は共有 .chip（@niqostudio/ui）。
// mono=技術スタック・スキル等のコード系（既定）/ soft=日本語の対応領域など柔らかいタグ。
interface Props {
  variant?: 'mono' | 'soft';
  class?: string;
}
const { variant = 'mono', class: className } = Astro.props;
---

<li class:list={['chip', `chip-${variant}`, className]}>
  <slot />
</li>
