---
import type { HTMLAttributes } from 'astro/types';

// カード面。href があればリンク化し hover で緑枠（.card-interactive）。
// as で要素を切替（div 既定 / article / section）。余白・レイアウトは class で指定。
interface Props extends HTMLAttributes<'a'> {
  href?: string;
  as?: 'div' | 'article' | 'section';
  class?: string;
}

const { href, as = 'div', class: className, ...rest } = Astro.props;
const Tag = href ? 'a' : as;
---

<Tag
  href={href}
  class:list={['card', href && 'card-interactive', className]}
  {...rest}
>
  <slot />
</Tag>
