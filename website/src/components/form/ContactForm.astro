---
import { INQUIRY_LIMITS } from '../../config/inquiry';
// Turnstile（ボット対策）。サイトキーは公開値。未設定ならウィジェットを出さない（dev/未導入でも動く）。
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<form id="contact-form" method="POST" action="/api/contact" class="flex flex-col gap-5">
  <label class="flex flex-col gap-1 text-sm">
    <span>お名前 <span class="text-muted">*</span></span>
    <input
      type="text"
      name="name"
      required
      maxlength={INQUIRY_LIMITS.name}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
    <span class="text-xs text-muted">本名でなくても、お呼びする名前で構いません。</span>
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>会社名</span>
    <input
      type="text"
      name="company"
      maxlength={INQUIRY_LIMITS.company}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>メールアドレス <span class="text-muted">*</span></span>
    <input
      type="email"
      name="email"
      required
      maxlength={INQUIRY_LIMITS.email}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>お問い合わせ内容 <span class="text-muted">*</span></span>
    <textarea
      name="message"
      required
      maxlength={INQUIRY_LIMITS.message}
      rows="6"
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none resize-y"
    ></textarea>
  </label>

  {turnstileSiteKey && <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>}

  <button
    type="submit"
    class="self-start bg-accent text-bg rounded-md px-5 py-2.5 text-sm hover:opacity-90 transition-opacity disabled:opacity-50"
  >
    送信する
  </button>

  <p id="contact-status" class="text-sm" role="status" aria-live="polite"></p>
</form>

{
  turnstileSiteKey && (
    <script is:inline id="cf-turnstile-script" src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  )
}

<script>
  type Turnstile = { render: (el: Element) => string; reset: (id?: string) => void };

  // ClientRouter 遷移後も効くよう astro:page-load で初期化（初回ロードでも発火）。
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    const status = document.getElementById('contact-status');
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    // Turnstile は explicit レンダリング（api.js の ?render=explicit）。自動描画を止め二重描画を防ぐ。
    // 既ロードなら即描画（クライアント遷移）、未ロードは api.js の load を待つ（初回ロード）。
    const widget = form.querySelector('.cf-turnstile');
    let widgetId: string | undefined;
    const getTurnstile = () => (window as unknown as { turnstile?: Turnstile }).turnstile;
    const render = () => {
      const ts = getTurnstile();
      if (!ts || !widget || widget.querySelector('iframe')) return;
      widgetId = ts.render(widget);
    };
    if (widget) {
      if (getTurnstile()) render();
      else document.getElementById('cf-turnstile-script')?.addEventListener('load', render, { once: true });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !button) return;

      // client validation: 必須・email 形式・長さ（maxlength）をネイティブ制約で検証し、不備は UI を出して中断。
      if (!form.reportValidity()) return;

      button.disabled = true;
      status.textContent = '送信中…';
      status.className = 'text-sm text-muted';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
        });
        if (!res.ok) throw new Error('failed');
        form.reset();
        getTurnstile()?.reset(widgetId);
        status.textContent =
          '送信しました。確認メールをお送りしました。数分内に届かない場合は、メールアドレスをご確認のうえ再送信ください。';
        status.className = 'text-sm';
      } catch {
        status.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
        status.className = 'text-sm text-error';
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
