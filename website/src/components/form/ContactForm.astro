---
import { INQUIRY_LIMITS, INQUIRY_FORM } from '../../config/inquiry';
// Turnstile（ボット対策）。サイトキーは公開値。未設定ならウィジェットを出さない（dev/未導入でも動く）。
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const sched = INQUIRY_FORM.schedule;
---

<form id="contact-form" method="POST" action="/api/contact" class="flex flex-col gap-5">
  <label class="flex flex-col gap-1 text-sm">
    <span>お名前 <span class="text-muted">*</span></span>
    <input
      type="text"
      name="name"
      required
      maxlength={INQUIRY_LIMITS.name}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
    <span class="text-xs text-muted">本名でなくても、お呼びする名前で構いません。</span>
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>会社名</span>
    <input
      type="text"
      name="company"
      maxlength={INQUIRY_LIMITS.company}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>メールアドレス <span class="text-muted">*</span></span>
    <input
      type="email"
      name="email"
      required
      maxlength={INQUIRY_LIMITS.email}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none"
    />
  </label>

  <label class="flex flex-col gap-1 text-sm">
    <span>お問い合わせ内容 <span class="text-muted">*</span></span>
    <textarea
      id="contact-message"
      name="message"
      required
      maxlength={INQUIRY_LIMITS.message}
      rows="6"
      placeholder={INQUIRY_FORM.message_placeholder}
      class="bg-surface border border-border rounded-sm px-3 py-2 focus:border-accent outline-none resize-y placeholder:text-muted"
    ></textarea>
  </label>

  {/* 無料相談の希望日程ピッカー。日付を選び時間帯タップで候補に即追加。送信時にだけ message へ添付する（textarea は自由記述のまま）。 */}
  <fieldset id="sched" class="flex flex-col gap-3 text-sm border border-border-subtle rounded-sm p-4">
    <legend class="px-1 text-xs font-mono uppercase tracking-wide text-muted">{sched.heading}</legend>

    <div class="flex items-center justify-between">
      <button type="button" id="sched-prev" aria-label="前の月" class="rounded-sm px-2 py-1 hover:bg-bg disabled:opacity-30">‹</button>
      <span id="sched-month" class="font-mono"></span>
      <button type="button" id="sched-next" aria-label="次の月" class="rounded-sm px-2 py-1 hover:bg-bg disabled:opacity-30">›</button>
    </div>

    <div id="sched-grid" class="grid grid-cols-7 gap-1 text-center text-xs"></div>

    <div class="flex flex-col gap-1">
      <span class="text-xs text-muted">時間帯（日付を選んでタップで追加・最大{sched.max_candidates}件）</span>
      <div id="sched-bands" class="flex flex-wrap gap-2"></div>
    </div>

    <ul id="sched-list" class="flex flex-col gap-1 text-xs"></ul>
  </fieldset>

  {turnstileSiteKey && <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="auto"></div>}

  <button
    type="submit"
    class="self-start bg-accent text-bg rounded-md px-5 py-2.5 text-sm hover:opacity-90 transition-opacity disabled:opacity-50"
  >
    送信する
  </button>

  <p id="contact-status" class="text-sm" role="status" aria-live="polite"></p>
</form>

{
  turnstileSiteKey && (
    <script is:inline id="cf-turnstile-script" src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
  )
}

<script>
  type Turnstile = { render: (el: Element) => string; reset: (id?: string) => void };

  // ClientRouter 遷移後も効くよう astro:page-load で初期化（初回ロードでも発火）。
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;
    const status = document.getElementById('contact-status');
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    // 流入元は SourceCapture（全ページ）が初回ランディング時に sessionStorage へ保存する。
    // ここでは読み出して送信時の本文へ添付するだけ。フォームのあるページ（変換地点）も併記する。
    const sourceBlock = (): string => {
      const lines: string[] = [];
      try {
        const raw = sessionStorage.getItem('niqo_src');
        if (raw) {
          const d = JSON.parse(raw) as { utm?: Record<string, string>; ref?: string; landing?: string };
          for (const [k, v] of Object.entries(d.utm ?? {})) lines.push(`${k}: ${v}`);
          if (d.ref) lines.push(`referrer: ${d.ref}`);
          if (d.landing) lines.push(`landing: ${d.landing}`);
        }
      } catch {}
      lines.push(`form: ${location.pathname}`);
      return '【流入元】\n' + lines.join('\n');
    };

    // Turnstile は explicit レンダリング（api.js の ?render=explicit）。自動描画を止め二重描画を防ぐ。
    // 既ロードなら即描画（クライアント遷移）、未ロードは api.js の load を待つ（初回ロード）。
    const widget = form.querySelector('.cf-turnstile');
    let widgetId: string | undefined;
    const getTurnstile = () => (window as unknown as { turnstile?: Turnstile }).turnstile;
    const render = () => {
      const ts = getTurnstile();
      if (!ts || !widget || widget.querySelector('iframe')) return;
      widgetId = ts.render(widget);
    };
    if (widget) {
      if (getTurnstile()) render();
      else document.getElementById('cf-turnstile-script')?.addEventListener('load', render, { once: true });
    }

    // 無料相談のご希望日程ピッカー。日付を選び時間帯をタップで候補に即追加（最大 max_candidates）。
    // 本文には書き込まず、送信時にだけ message へ希望日程を添付する（textarea は自由記述のまま）。書式の正本は config の inquiry_form。
    let scheduleBlock = (): string => '';
    const messageEl = document.getElementById('contact-message') as HTMLTextAreaElement | null;
    const grid = document.getElementById('sched-grid');
    if (messageEl && grid) {
      const cfg = __INQUIRY_FORM__.schedule;
      const monthLabel = document.getElementById('sched-month') as HTMLElement;
      const bandsEl = document.getElementById('sched-bands') as HTMLElement;
      const listEl = document.getElementById('sched-list') as HTMLElement;
      const prevBtn = document.getElementById('sched-prev') as HTMLButtonElement;
      const nextBtn = document.getElementById('sched-next') as HTMLButtonElement;

      const WEEK = ['日', '月', '火', '水', '木', '金', '土'];
      const iso = (d: Date) =>
        `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const minMonth = new Date(today.getFullYear(), today.getMonth(), 1);
      // 選択可能なのは今日〜「今月＋months_ahead か月」の末日まで。
      const maxDate = new Date(today.getFullYear(), today.getMonth() + cfg.months_ahead + 1, 0);
      const maxMonth = new Date(maxDate.getFullYear(), maxDate.getMonth(), 1);

      let view = new Date(minMonth);
      let selDate: Date | null = null;
      type Cand = { iso: string; label: string; band: string; wd: number };
      const cands: Cand[] = [];
      const full = () => cands.length >= cfg.max_candidates;
      const has = (isoStr: string, band: string) => cands.some((c) => c.iso === isoStr && c.band === band);

      const lineFor = (i: number, c: Cand) =>
        cfg.line_format
          .replace('{n}', String(i + 1))
          .replace('{date}', c.label)
          .replace('{weekday}', WEEK[c.wd])
          .replace('{band}', c.band);

      // 送信時に message へ添付する希望日程ブロック（候補が無ければ空文字）。
      scheduleBlock = () => (cands.length ? cfg.block_label + '\n' + cands.map((c, i) => lineFor(i, c)).join('\n') : '');

      const renderBands = () => {
        bandsEl.replaceChildren();
        for (const band of cfg.time_bands) {
          const disabled = selDate === null || full() || has(iso(selDate), band);
          const b = document.createElement('button');
          b.type = 'button';
          b.textContent = band;
          b.disabled = disabled;
          b.className =
            'rounded-sm border px-3 py-1 text-xs transition-colors ' +
            (disabled
              ? 'border-border-subtle text-border cursor-not-allowed'
              : 'border-border text-muted hover:border-accent hover:text-accent');
          // 日付選択済みなら時間帯タップで即・候補に追加。
          if (!disabled) {
            b.addEventListener('click', () => {
              if (selDate === null || full()) return;
              cands.push({ iso: iso(selDate), label: `${selDate.getMonth() + 1}/${selDate.getDate()}`, band, wd: selDate.getDay() });
              renderList();
              renderBands();
            });
          }
          bandsEl.appendChild(b);
        }
      };

      const renderList = () => {
        listEl.replaceChildren();
        cands.forEach((c, i) => {
          const li = document.createElement('li');
          li.className = 'flex items-center gap-2 text-muted';
          const span = document.createElement('span');
          span.textContent = lineFor(i, c);
          const rm = document.createElement('button');
          rm.type = 'button';
          rm.textContent = '削除';
          rm.className = 'text-error hover:underline';
          rm.addEventListener('click', () => {
            cands.splice(i, 1);
            renderList();
            renderBands();
          });
          li.append(span, rm);
          listEl.appendChild(li);
        });
      };

      const renderCalendar = () => {
        grid.replaceChildren();
        monthLabel.textContent = `${view.getFullYear()}年 ${view.getMonth() + 1}月`;
        for (const w of WEEK) {
          const h = document.createElement('span');
          h.textContent = w;
          h.className = 'py-1 text-muted';
          grid.appendChild(h);
        }
        const blanks = new Date(view.getFullYear(), view.getMonth(), 1).getDay();
        for (let i = 0; i < blanks; i++) grid.appendChild(document.createElement('span'));
        const days = new Date(view.getFullYear(), view.getMonth() + 1, 0).getDate();
        for (let d = 1; d <= days; d++) {
          const date = new Date(view.getFullYear(), view.getMonth(), d);
          // 受付曜日（working_days）かつ 今日〜maxDate の範囲だけ選択可。
          const disabled = date < today || date > maxDate || !cfg.working_days.includes(date.getDay());
          const isSel = selDate !== null && iso(selDate) === iso(date);
          const cell = document.createElement('button');
          cell.type = 'button';
          cell.textContent = String(d);
          cell.disabled = disabled;
          cell.className =
            'rounded-sm py-1 transition-colors ' +
            (disabled ? 'text-border cursor-not-allowed' : isSel ? 'bg-accent text-bg' : 'hover:bg-bg');
          if (!disabled) {
            cell.addEventListener('click', () => {
              selDate = date;
              renderCalendar();
              renderBands();
            });
          }
          grid.appendChild(cell);
        }
        prevBtn.disabled = view <= minMonth;
        nextBtn.disabled = view >= maxMonth;
      };

      prevBtn.addEventListener('click', () => {
        view = new Date(view.getFullYear(), view.getMonth() - 1, 1);
        renderCalendar();
      });
      nextBtn.addEventListener('click', () => {
        view = new Date(view.getFullYear(), view.getMonth() + 1, 1);
        renderCalendar();
      });
      // 送信成功時の form.reset() で希望日程の選択もクリアする。
      form.addEventListener('reset', () => {
        cands.length = 0;
        selDate = null;
        renderList();
        renderBands();
        renderCalendar();
      });

      renderCalendar();
      renderBands();
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !button) return;

      // client validation: 必須・email 形式・長さ（maxlength）をネイティブ制約で検証し、不備は UI を出して中断。
      if (!form.reportValidity()) return;

      button.disabled = true;
      status.textContent = '送信中…';
      status.className = 'text-sm text-muted';

      try {
        // 希望日程・流入元は本文に書き込まず、送信時にだけ message へ添付する。
        const fd = new FormData(form);
        const extras = [scheduleBlock(), sourceBlock()].filter(Boolean).join('\n\n');
        if (extras) {
          const msg = (fd.get('message') as string) ?? '';
          fd.set('message', msg ? `${msg}\n\n${extras}` : extras);
        }
        const res = await fetch('/api/contact', { method: 'POST', body: fd });
        if (!res.ok) throw new Error('failed');
        form.reset();
        getTurnstile()?.reset(widgetId);
        status.textContent =
          '送信しました。確認メールをお送りしました。数分内に届かない場合は、メールアドレスをご確認のうえ再送信ください。';
        status.className = 'text-sm';
      } catch {
        status.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
        status.className = 'text-sm text-error';
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
