---
import '../styles/global.css';
import '../styles/lp.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import SourceCapture from '../components/SourceCapture.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description: string;
  // 構造化データ（Service / FAQPage 等）。LP は本体の breadcrumb/Shell を使わず自前で出す。
  structuredData?: object[];
  // OG 画像キー（public/og/<key>.png）。prebuild の scripts/og.mjs で生成する。
  ogKey?: string;
  // ヘッダー右の CTA リンク先（ページ内アンカー想定）。
  ctaHref?: string;
}

const { title, description, structuredData = [], ogKey = 'ai-automation', ctaHref = '#contact' } = Astro.props;

const fullTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`/og/${ogKey}.png`, Astro.site);

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: SITE.name,
  url: Astro.site?.href,
  description: SITE.description,
  areaServed: 'JP',
};
const schemas = [orgLd, ...structuredData];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* ContactForm 等のクライアント初期化は astro:page-load 発火に依存するため必須。 */}
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-noto-jp" />
    <Font cssVariable="--font-jetbrains-mono" />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonical.href} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    {schemas.map((s) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <SourceCapture />
    <div class="lp">
      <header class="lp-bleed">
        <div class="lp-inner lp-inner--wide lp-header">
          <a href="/" class="lp-wordmark">NIQO STUDIO</a>
          <a href={ctaHref} class="lp-header-cta">無料相談</a>
        </div>
      </header>

      <slot />

      <footer class="lp-bleed">
        <div class="lp-inner lp-inner--wide lp-footer">
          <span>© {SITE.name}</span>
          <nav class="lp-footer-links">
            <a href="/">サイトトップ</a>
            <a href="/services">サービス</a>
            <a href="/privacy">プライバシー</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
