---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorks, getProfile, getServices } from '../lib/content';
import { SITE, HOME } from '../config/site';
import { WorkCard, Card, Button, LogoMark, SectionLabel, ArrowLink, Jp } from '../components';

const works = (await getWorks()).slice(0, 3);
const services = await getServices();
const profile = await getProfile();

const steps = [
  { name: 'Consult', desc: '30分のオンライン無料相談で課題と進め方をすり合わせ。' },
  { name: 'Discovery', desc: '有償の事前設計で要件・技術・費用を固める。' },
  { name: 'Build', desc: '設計・実装。サイトから業務システムまで一貫構築。' },
  { name: 'Operate', desc: 'デプロイ後もアフターケアで継続的に支える。' },
];
---

<BaseLayout width="wide" title={HOME.title} description={HOME.description}>
  <section class="relative isolate overflow-hidden py-8">
    <div
      class="pointer-events-none absolute right-0 top-1/2 -z-10 aspect-square w-[24rem] -translate-y-1/2 text-border-subtle opacity-50 [--logo-pair:currentColor] [--logo-diag:currentColor] sm:w-[24rem] lg:w-[30rem]"
      aria-hidden="true"
    >
      <LogoMark class="h-full w-full" />
    </div>
    <h1>
      <span class="block font-mono text-sm text-muted uppercase tracking-wide">{SITE.name}</span>
      {
        profile?.tagline && (
          <span class="block text-4xl sm:text-5xl font-semibold tracking-tight mt-3">
            {profile.tagline}
          </span>
        )
      }
    </h1>
    <p class="text-lg text-muted mt-4 max-w-xl">
      <Jp
        text="設計から運用まで一貫して通す業務委託エンジニア。中小事業者・スタートアップの Web・業務システムを作ります。"
      />
    </p>
    <div class="flex gap-4 mt-8">
      <Button href="/contact">無料相談する</Button>
      <Button href="/services" variant="secondary">サービスを見る</Button>
    </div>
  </section>

  <section class="py-12 border-t border-border mt-8">
    <SectionLabel as="h2">Process</SectionLabel>
    <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, i) => (
          <div>
            <p class="font-mono text-3xl text-accent">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="font-semibold text-xl mt-3">{step.name}</h3>
            <p class="text-sm text-muted mt-2">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  {
    services.length > 0 && (
      <section class="py-12 border-t border-border">
        <div class="flex items-baseline justify-between">
          <SectionLabel as="h2">Services</SectionLabel>
          <ArrowLink href="/services" class="text-sm text-muted hover:text-accent transition-colors">
            サービス一覧を見る
          </ArrowLink>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 mt-6">
          {
            services.map((service) => {
              const basePrice = service.pricing?.base_price ?? null;
              const tiers = service.pricing?.tiers ?? [];
              const lead = service.headline ?? service.summary;
              const primary = service.enPrimary ? service.name : (service.nameJa ?? service.name);
              const sub = service.enPrimary ? service.nameJa : service.nameJa ? service.name : null;
              return (
                <Card href={`/services#${service.slug}`} class="block p-6">
                  <h3 class="font-medium text-lg">
                    {primary}
                    {sub && <span class="text-muted text-sm ml-1.5">{sub}</span>}
                  </h3>
                  {lead && (
                    <p class="text-sm text-muted mt-2">
                      <Jp text={lead} />
                    </p>
                  )}
                  <dl class="grid grid-cols-[4rem_1fr] gap-x-3 gap-y-2 text-sm mt-4">
                    {(basePrice || tiers.length > 0) && (
                      <Fragment>
                        <dt class="text-muted">料金</dt>
                        <dd>
                          {basePrice && <p class="font-mono">{basePrice}</p>}
                          {tiers.length > 0 && (
                            <ul class="flex flex-col gap-0.5">
                              {tiers.map((tier) => (
                                <li class="flex items-baseline justify-between gap-3">
                                  <span>{tier.name}</span>
                                  <span class="font-mono text-muted whitespace-nowrap">{tier.price}</span>
                                </li>
                              ))}
                            </ul>
                          )}
                        </dd>
                      </Fragment>
                    )}
                    {service.duration && (
                      <Fragment>
                        <dt class="text-muted">期間</dt>
                        <dd>{service.duration}</dd>
                      </Fragment>
                    )}
                  </dl>
                </Card>
              );
            })
          }
        </div>
      </section>
    )
  }

  {
    works.length > 0 && (
      <section class="py-12 border-t border-border">
        <div class="flex items-baseline justify-between">
          <SectionLabel as="h2">Works</SectionLabel>
          <ArrowLink href="/works" class="text-sm text-muted hover:text-accent transition-colors">実績一覧を見る</ArrowLink>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-6">
          {works.map((work) => (
            <WorkCard work={work} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
