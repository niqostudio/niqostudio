---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorks, getProfile, getServices } from '../lib/content';
import { SITE, HOME } from '../config/site';
import { WorkCard, ServiceCard, Button, LogoMark, SectionLabel, ArrowLink, Jp } from '../components';

const works = (await getWorks()).slice(0, 3);
const services = await getServices();
const profile = await getProfile();

const steps = [
  { name: 'Consult', desc: '30分のオンライン無料相談で課題と進め方をすり合わせ。' },
  { name: 'Discovery', desc: '有償の事前設計で要件・技術・費用を固める。' },
  { name: 'Build', desc: '設計・実装。サイトから業務システムまで一貫構築。' },
  { name: 'Operate', desc: 'デプロイ後もアフターケアで継続的に支える。' },
];
---

<BaseLayout width="wide" title={HOME.title} description={HOME.description}>
  {/* 内容は上下中央寄せ（flex + justify-center）。ウォーターマークは inset-y-0 h-full＝セクション高さ 100%で全表示。
      高さ＝ウォーターマークの大きさ＝上下余白の量は min-h で決まる（小さくすると余白も watermark も縮む）。
      -mt-6 で nav との間を詰める。 */}
  <section class="relative isolate -mt-6 flex min-h-[26rem] flex-col justify-center overflow-hidden">
    <div
      class="pointer-events-none absolute inset-y-0 right-0 -z-10 aspect-square h-full text-border-subtle opacity-50 [--logo-pair:currentColor] [--logo-diag:currentColor]"
      aria-hidden="true"
    >
      <LogoMark class="h-full w-full" cover />
    </div>
    <h1>
      <span class="block font-mono text-sm text-muted uppercase tracking-wide">{SITE.name}</span>
      {
        profile?.tagline && (
          <span class="block text-4xl sm:text-5xl font-semibold tracking-tight mt-3">
            {profile.tagline}
          </span>
        )
      }
    </h1>
    <p class="text-xl sm:text-2xl font-medium tracking-tight text-accent mt-2">速く、賢く、ちょうどよく―</p>
    <p class="text-base text-muted mt-3 max-w-xl">
      <Jp text="運用の痛みを設計で断つ、業務委託エンジニア。" />
    </p>
    <div class="flex gap-4 mt-8">
      <Button href="/contact">無料相談する</Button>
      <Button href="/services" variant="secondary">サービスを見る</Button>
    </div>
  </section>

  <section class="py-12 border-t border-border mt-8">
    <SectionLabel as="h2">Process</SectionLabel>
    <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((step, i) => (
          <div>
            <p class="font-mono text-3xl text-accent">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="font-semibold text-xl mt-3">{step.name}</h3>
            <p class="text-sm text-muted mt-2">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  {
    services.length > 0 && (
      <section class="py-12 border-t border-border">
        <div class="flex items-baseline justify-between">
          <SectionLabel as="h2">Services</SectionLabel>
          <ArrowLink href="/services" class="text-sm text-muted hover:text-accent transition-colors">
            サービス一覧を見る
          </ArrowLink>
        </div>
        <div class="grid gap-4 mt-6 sm:grid-cols-2 lg:grid-cols-4">
          {services.map((service) => (
            <ServiceCard service={service} compact />
          ))}
        </div>
      </section>
    )
  }

  {
    works.length > 0 && (
      <section class="py-12 border-t border-border">
        <div class="flex items-baseline justify-between">
          <SectionLabel as="h2">Works</SectionLabel>
          <ArrowLink href="/works" class="text-sm text-muted hover:text-accent transition-colors">実績一覧を見る</ArrowLink>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-6">
          {works.map((work) => (
            <WorkCard work={work} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
