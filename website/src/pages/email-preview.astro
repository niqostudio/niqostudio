---
// dev 専用のメール HTML プレビュー。?type=auto / owner で実テンプレートをそのまま返す（site の CSP/レイアウトを介さず素の HTML）。
// 本番ビルドでは 404（dev サーバでのみ閲覧）。
export const prerender = false;
import { autoReplyHtml, ownerNotificationHtml, type InquiryMail } from '../lib/email';

if (!import.meta.env.DEV) return new Response('Not found', { status: 404 });

const sample: InquiryMail = {
  name: '山田 太郎',
  company: '株式会社サンプル',
  email: 'taro@example.com',
  subject: 'Web サイト制作の相談',
  message: 'お世話になります。\n新規 EC サイトの構築を検討しています。\nよろしくお願いいたします。',
};

const type = Astro.url.searchParams.get('type');
const headers = { 'content-type': 'text/html; charset=utf-8' };
if (type === 'auto') return new Response(autoReplyHtml(sample), { headers });
if (type === 'owner') return new Response(ownerNotificationHtml(sample), { headers });
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>Email preview (dev)</title>
  </head>
  <body style="font-family:sans-serif;max-width:640px;margin:2rem auto;padding:0 1rem">
    <h1>Email preview（dev 専用）</h1>
    <p>実際の送信テンプレート（`lib/email.ts`）をサンプルデータで描画します。</p>
    <ul>
      <li><a href="/email-preview?type=auto">① 自動返信（顧客宛・noreply）</a></li>
      <li><a href="/email-preview?type=owner">② 管理者通知（hi@ 宛・From=顧客名/Reply-To=顧客）</a></li>
    </ul>
    <p style="color:#888;font-size:.85rem">本番ビルドでは 404。サンプルは固定値。</p>
  </body>
</html>
