---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getWorks, getWork } from '../../lib/content';
import { SITE, PAGES } from '../../config/site';
import { SectionLabel, ArrowLink, Card, Chip, Jp } from '../../components';

export async function getStaticPaths() {
  const works = await getWorks();
  return works.map((work) => ({ params: { slug: work.slug } }));
}

const { slug } = Astro.params;
const work = await getWork(slug!);

if (!work) {
  return Astro.redirect('/works');
}

const meta = [work.client?.name, work.period].filter(Boolean).join(' · ');

const workImage = work.images[0] ?? work.thumbnail;
const workSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: work.title,
  ...(work.summary ? { description: work.summary } : {}),
  ...(workImage ? { image: new URL(workImage, Astro.site).href } : {}),
  ...(work.techStack.length > 0 ? { keywords: work.techStack.join(', ') } : {}),
  ...(work.publicUrl ? { url: work.publicUrl } : {}),
  creator: { '@type': 'ProfessionalService', name: SITE.name },
};
---

<BaseLayout title={work.title} description={work.summary ?? undefined} structuredData={workSchema}>
  <ArrowLink
    href={PAGES.works.href}
    arrow="before"
    class="text-sm text-muted hover:text-accent transition-colors"
  >
    {PAGES.works.title}
  </ArrowLink>

  <h1 class="text-3xl font-semibold tracking-tight mt-4">{work.title}</h1>
  {meta && <p class="text-muted mt-2">{meta}</p>}

  {work.summary && <p class="text-lg mt-6"><Jp text={work.summary} /></p>}

  {
    work.scope.length > 0 && (
      <div class="mt-8">
        <SectionLabel>Scope</SectionLabel>
        <p class="mt-2">{work.scope.join(' / ')}</p>
      </div>
    )
  }

  {
    work.techStack.length > 0 && (
      <div class="mt-6">
        <SectionLabel>Tech stack</SectionLabel>
        <ul class="flex flex-wrap gap-1.5 mt-2">
          {work.techStack.map((t) => (
            <Chip>{t}</Chip>
          ))}
        </ul>
      </div>
    )
  }

  {
    work.images.length > 0 && (
      <div class="grid gap-4 mt-8">
        {work.images.map((url) => (
          <img src={url} alt={work.title} loading="lazy" class="w-full rounded-sm" />
        ))}
      </div>
    )
  }

  {
    work.publicUrl && (
      <p class="mt-8">
        <ArrowLink href={work.publicUrl} target="_blank" rel="noopener" underline class="text-accent">
          公開サイトを見る
        </ArrowLink>
      </p>
    )
  }

  {
    work.relatedCases.length > 0 && (
      <div class="mt-10 border-t border-border pt-6">
        <SectionLabel>関連ケーススタディ</SectionLabel>
        <div class="grid sm:grid-cols-2 gap-4 mt-3">
          {work.relatedCases.map((c) => (
            <Card href={`/cases/${c.slug}`} class="group block p-5">
              <p class="font-medium">{c.title}</p>
              <span class="mt-2 inline-flex items-center gap-1 text-sm text-accent">
                ケーススタディを見る
                <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </Card>
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>
