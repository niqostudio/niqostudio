---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCases, getCase } from '../../lib/content';
import { SITE, PAGES } from '../../config/site';
import { SectionLabel, ArrowLink, Card, Chip, Jp } from '../../components';
import { marked } from 'marked';

export async function getStaticPaths() {
  const cases = await getCases();
  return cases.map((caseItem) => ({ params: { slug: caseItem.slug } }));
}

const { slug } = Astro.params;
const caseItem = await getCase(slug!);

if (!caseItem) {
  return Astro.redirect(PAGES.cases.href);
}

const desc = caseItem.summary ?? caseItem.problems[0]?.problem;
const heroImage = caseItem.thumbnail ?? caseItem.deliverables.flatMap((d) => d.images)[0];
const liveUrl = caseItem.deliverables.find((d) => d.url)?.url;
const meta = [caseItem.client?.name, caseItem.period].filter(Boolean).join(' · ');
// 本文は operator が studio（service_role）で書く一次情報＝信頼コンテンツ。CSP がインライン実行を防ぐ。
const bodyHtml = caseItem.body ? (marked.parse(caseItem.body) as string) : null;
const KIND_LABELS: Record<string, string> = {
  public_web: '公開Web',
  cms: 'CMS',
  business_system: '業務システム',
  operations: '運用',
  app: 'アプリ',
  docs: 'ドキュメント',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: caseItem.title,
  ...(desc ? { description: desc } : {}),
  ...(heroImage ? { image: new URL(heroImage, Astro.site).href } : {}),
  ...(caseItem.techStack.length > 0 ? { keywords: caseItem.techStack.join(', ') } : {}),
  ...(liveUrl ? { url: liveUrl } : {}),
  ...(caseItem.client?.industry ? { about: caseItem.client.industry } : {}),
  creator: { '@type': 'ProfessionalService', name: SITE.name },
};
---

<BaseLayout title={caseItem.title} description={desc ?? undefined} structuredData={schema}>
  <ArrowLink
    href={PAGES.cases.href}
    arrow="before"
    class="text-sm text-muted hover:text-accent transition-colors"
  >
    ケーススタディ一覧へ戻る
  </ArrowLink>

  <h1 class="text-3xl font-semibold tracking-tight mt-4">{caseItem.title}</h1>
  {meta && <p class="text-muted mt-2">{meta}</p>}

  {caseItem.summary && <p class="text-lg mt-6"><Jp text={caseItem.summary} /></p>}

  {
    caseItem.problems.length > 0 && (
      <section class="mt-10">
        <SectionLabel as="h2">課題と解決</SectionLabel>
        <div class="mt-4 flex flex-col gap-8">
          {caseItem.problems.map((p) => (
            <div class="border-l-2 border-border-subtle pl-4 flex flex-col gap-3">
              <div>
                <p class="font-mono text-xs uppercase tracking-wide text-muted">課題</p>
                <p class="mt-1"><Jp text={p.problem} /></p>
              </div>
              {p.solution && (
                <div>
                  <p class="font-mono text-xs uppercase tracking-wide text-muted">アプローチ</p>
                  <p class="mt-1"><Jp text={p.solution} /></p>
                </div>
              )}
              {p.outcome && (
                <div>
                  <p class="font-mono text-xs uppercase tracking-wide text-accent">成果</p>
                  <p class="mt-1"><Jp text={p.outcome} /></p>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    caseItem.metrics.length > 0 && (
      <section class="mt-8">
        <SectionLabel as="h2">数値</SectionLabel>
        <table class="w-full mt-3 text-sm border border-border rounded-sm overflow-hidden">
          <thead>
            <tr class="text-left text-muted border-b border-border">
              <th class="px-3 py-2 font-normal">指標</th>
              <th class="px-3 py-2 font-normal text-center">Before</th>
              <th class="px-3 py-2 font-normal text-center">After</th>
            </tr>
          </thead>
          <tbody>
            {caseItem.metrics.map((m) => (
              <tr class="border-b border-border last:border-0">
                <td class="px-3 py-2">{m.label}{m.unit ? ` (${m.unit})` : ''}</td>
                <td class="px-3 py-2 text-muted text-center">{m.previous ?? '—'}</td>
                <td class="px-3 py-2 font-medium text-accent text-center">{m.achieved}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )
  }

  {
    caseItem.deliverables.length > 0 && (
      <section class="mt-8">
        <SectionLabel as="h2">作ったもの</SectionLabel>
        <div class="mt-3 flex flex-col gap-6">
          {caseItem.deliverables.map((d) => (
            <div>
              <div class="flex flex-wrap items-baseline gap-2">
                <Chip>{KIND_LABELS[d.kind] ?? d.kind}</Chip>
                {d.url ? (
                  <a href={d.url} target="_blank" rel="noopener" class="text-accent hover:underline">
                    {d.name}
                  </a>
                ) : (
                  <span class="font-medium">{d.name}</span>
                )}
              </div>
              {d.images.length > 0 && (
                <div class="grid gap-3 mt-3">
                  {d.images.map((url) => (
                    <img src={url} alt={d.name} loading="lazy" class="w-full rounded-sm" />
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    caseItem.techStack.length > 0 && (
      <section class="mt-8">
        <SectionLabel as="h2">技術・基盤</SectionLabel>
        <ul class="flex flex-wrap gap-1.5 mt-2">
          {caseItem.techStack.map((t) => (
            <Chip>{t}</Chip>
          ))}
        </ul>
      </section>
    )
  }

  {bodyHtml && <div class="case-body mt-8" set:html={bodyHtml} />}

  {
    caseItem.testimonial && (
      <figure class="mt-8 border-l-2 border-accent pl-4">
        <blockquote class="text-lg"><Jp text={caseItem.testimonial.quote} /></blockquote>
        {caseItem.testimonial.role && <figcaption class="text-sm text-muted mt-2">— {caseItem.testimonial.role}</figcaption>}
      </figure>
    )
  }

  {
    caseItem.related.length > 0 && (
      <div class="mt-10 border-t border-border pt-6">
        <SectionLabel>関連ケース</SectionLabel>
        <div class="grid sm:grid-cols-2 gap-4 mt-3">
          {caseItem.related.map((r) => (
            <Card href={`/cases/${r.slug}`} class="group block p-5">
              <p class="font-medium">{r.title}</p>
              <span class="mt-2 inline-flex items-center gap-1 text-sm text-accent">
                ケースを見る
                <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </Card>
          ))}
        </div>
      </div>
    )
  }
</BaseLayout>
