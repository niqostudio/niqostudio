---
// 英語圏向けの単一ページ。SaaS 製品からの「by NIQO STUDIO」導線の着地先。
// サイト本体（日本語・受託向け）の Shell は日本語ナビ/CTA/パンくず前提のため使わず、
// トークン・部品（LogoMark / Wordmark / SectionLabel / Button）だけ共有する self-contained 構成。
import '../styles/global.css';
import { Font } from 'astro:assets';
import { SITE, THEME } from '../config/site';
import LogoMark from '../components/ui/LogoMark.astro';
import Wordmark from '../components/ui/Wordmark.astro';
import SectionLabel from '../components/ui/SectionLabel.astro';
import Button from '../components/ui/Button.astro';

const title = `${SITE.name} — Independent software studio in Japan`;
const description =
  'NIQO STUDIO is an independent software studio based in Japan. We build and operate SaaS products, and provide software design, development, and operations for businesses in Japan.';
const canonical = new URL('/en', Astro.site);
// OG 画像はトップ用を流用（生成対象は日本語の固定ページのみ）。
const ogImage = new URL('/og/index.png', Astro.site);
const year = new Date().getFullYear();

const work = [
  {
    name: 'Products',
    desc: 'We build and operate our own SaaS products for a global audience. Each product has its own site, documentation, and support channel.',
  },
  {
    name: 'Client work',
    desc: 'Software consulting, design, development, and operations for small businesses and startups in Japan — offered in Japanese.',
  },
];
---

<!doctype html>
<html lang="en" data-theme={THEME}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" />
    <title>{title}</title>
    <link rel="canonical" href={canonical.href} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="w-full max-w-page mx-auto px-4 sm:px-6 lg:px-8 pt-6 flex items-center justify-between">
      <p class="inline-flex items-center gap-3">
        <LogoMark class="w-9 h-9" />
        <Wordmark class="text-sm" />
      </p>
      <a href="/" class="text-xs text-muted hover:text-fg tracking-wide transition-colors">Japanese site →</a>
    </header>

    <main class="flex-1 w-full max-w-page mx-auto px-4 sm:px-6 lg:px-8 py-12">
      {/* 日本語トップと同じヒーロー文法: 右にウォーターマーク・上下中央・min-h で余白量を決める */}
      <section class="relative isolate flex min-h-[24rem] flex-col justify-center overflow-hidden">
        <div
          class="pointer-events-none absolute inset-y-0 right-0 -z-10 aspect-square h-full text-border-subtle opacity-50 [--logo-pair:currentColor] [--logo-diag:currentColor]"
          aria-hidden="true"
        >
          <LogoMark class="h-full w-full" cover />
        </div>
        <h1>
          <span class="block font-mono text-sm text-muted uppercase tracking-wide">{SITE.name}</span>
          <span class="block text-4xl sm:text-5xl font-semibold tracking-tight mt-3">
            An independent software studio based in Japan.
          </span>
        </h1>
        <p class="text-xl sm:text-2xl font-medium tracking-tight text-accent mt-2">Fast, smart, just right —</p>
        <p class="text-base text-muted mt-3 max-w-xl">
          We design, build, and run software end to end: SaaS products for a global audience, and
          client work for businesses in Japan.
        </p>
        <div class="flex gap-4 mt-8">
          <Button href={`mailto:${SITE.email}`}>Get in touch</Button>
          <Button href="/" variant="secondary">Japanese site</Button>
        </div>
      </section>

      <section class="py-12 border-t border-border mt-8">
        <SectionLabel as="h2">What we do</SectionLabel>
        <div class="mt-8 grid gap-x-6 gap-y-7 sm:gap-8 sm:grid-cols-2">
          {
            work.map((item, i) => (
              <div class="flex items-baseline gap-4 sm:block">
                <p class="font-mono text-3xl text-accent">{String(i + 1).padStart(2, '0')}</p>
                <div class="sm:mt-3">
                  <h3 class="font-semibold text-xl">{item.name}</h3>
                  <p class="text-sm text-muted mt-1 sm:mt-2 max-w-md">{item.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="py-12 border-t border-border">
        <SectionLabel as="h2">Contact</SectionLabel>
        <p class="text-sm text-muted mt-6 max-w-xl">
          For product-specific questions, please use the support channel on the product&apos;s own site.
          For everything else:
          <a href={`mailto:${SITE.email}`} class="link-rich">{SITE.email}</a>
        </p>
      </section>
    </main>

    {/* 日本語サイトのフッターと同じダーク面・ゴールド罫の文法 */}
    <footer class="bg-surface-dark text-on-dark border-t-2 border-gold">
      <div class="max-w-page mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col items-center gap-6 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left">
        <p class="inline-flex items-center gap-3">
          <LogoMark class="w-10 h-10 [--logo-accent:var(--color-gold)]" />
          <Wordmark class="text-base" />
        </p>
        <p class="text-sm text-on-dark-muted max-w-xs">Fast, smart, just right.</p>
      </div>
      <div class="max-w-page mx-auto px-4 sm:px-6 lg:px-8 pb-10 flex flex-col items-center gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs text-on-dark-muted uppercase tracking-wide">&copy; {year} <Wordmark /></p>
        <a href="/privacy" class="text-xs text-on-dark-muted hover:text-on-dark tracking-wide transition-colors">
          Privacy policy (Japanese)
        </a>
      </div>
    </footer>
  </body>
</html>
