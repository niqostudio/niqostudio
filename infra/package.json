{
  "name": "@niqostudio/infra",
  "version": "0.0.0",
  "private": true,
  "description": "Platform provisioning: Supabase project (local stack) and Terraform (DNS/email/Pages/state)",
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "saas:start": "supabase --workdir supabase-saas start",
    "saas:stop": "supabase --workdir supabase-saas stop",
    "saas:status": "supabase --workdir supabase-saas status",
    "saas:reset": "supabase --workdir supabase-saas db reset",
    "login": "supabase login",
    "link": "supabase link",
    "types": "supabase gen types typescript --local --schema core > ../packages/db-types/src/database.ts",
    "types:saas": "supabase --workdir supabase-saas gen types typescript --local --schema identity > ../packages/db-types/src/saas-database.ts",
    "tf:init": "terraform init",
    "tf:plan": "terraform plan",
    "tf:apply": "terraform apply"
  },
  "devDependencies": {
    "@jahed/terraform": "1.15.7",
    "supabase": "^2.109.0"
  },
  "engines": {
    "node": ">=24"
  }
}
