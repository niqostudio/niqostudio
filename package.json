{
  "name": "niqostudio",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "db:start": "pnpm --filter @niqostudio/infra run db:start",
    "db:stop": "pnpm --filter @niqostudio/infra run db:stop",
    "db:status": "pnpm --filter @niqostudio/infra run db:status",
    "db:reset": "node scripts/db-reset.mjs",
    "db:types": "pnpm --filter @niqostudio/infra run types",
    "saas:start": "pnpm --filter @niqostudio/infra run saas:start",
    "saas:stop": "pnpm --filter @niqostudio/infra run saas:stop",
    "saas:status": "pnpm --filter @niqostudio/infra run saas:status",
    "saas:reset": "node scripts/saas-reset.mjs",
    "saas:test": "node --test \"saas-platform/tests/**/*.test.mjs\"",
    "saas:functions:serve": "node scripts/saas-functions-serve.mjs",
    "db:types:saas": "pnpm --filter @niqostudio/infra run types:saas",
    "release:dry": "node scripts/release.mjs",
    "release": "node scripts/release.mjs --apply",
    "niqo:up": "node scripts/niqo-up.mjs",
    "niqo:dev": "node scripts/niqo-dev.mjs",
    "niqo:dev:down": "node scripts/niqo-dev-down.mjs",
    "niqo:down": "node scripts/niqo-down.mjs",
    "dev:website": "pnpm --filter @niqostudio/website run dev",
    "dev:studio": "pnpm --filter @niqostudio/studio run dev",
    "test": "pnpm -r --if-present run test"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "dbmate": "2.33.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0"
  }
}
