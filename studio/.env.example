# このファイルをコピーして .env.local を作り、値を入れる（.env.local は gitignore 済み）。
# core(Supabase) への service_role 接続（サーバ専用・クライアントに出さない）。
# ローカルは `pnpm db:status` の値を使う。
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# 認証（operator ログイン）。anon/publishable キー＝ブラウザにも出る公開値。core(Supabase) の Auth を使う。
# ローカルは niqostudio-local の値（`pnpm db:status` の API URL / anon key）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# アクセスを許可する operator メール（カンマ区切り）。未設定なら全拒否。
STUDIO_ALLOWED_EMAILS=

# テナント（既定 niqostudio）。self-host で単テナント切替する時だけ設定。
# STUDIO_TENANT=niqostudio

# 公開デプロイ（website 再ビルド＆デプロイを studio から起動）。未設定ならダッシュボードにボタンを出さない。
# 簡易＝fine-grained PAT（対象 repo の Actions: Read and write）。org なら GitHub App 推奨：
#   GITHUB_APP_ID と、App 秘密鍵(.pem)を base64 化した GITHUB_APP_PRIVATE_KEY_B64 を入れる（installation は repo から自動解決）。
# どちらか一方でよい（PAT があれば優先）。GITHUB_REPO は owner/repo（既定 niqostudio/niqostudio）。
# GITHUB_TOKEN=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_B64=
# GITHUB_REPO=niqostudio/niqostudio
