# このファイルをコピーして .env.local を作り、値を入れる（.env.local は gitignore 済み）。
# core(Supabase) への service_role 接続（サーバ専用・クライアントに出さない）。
# ローカルは `pnpm db:status` の値を使う。
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# 認証（operator ログイン）。anon/publishable キー＝ブラウザにも出る公開値。core(Supabase) の Auth を使う。
# ローカルは niqostudio-local の値（`pnpm db:status` の API URL / anon key）。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# アクセスを許可する operator メール（カンマ区切り）。未設定なら全拒否。
STUDIO_ALLOWED_EMAILS=

# テナント（既定 niqostudio）。self-host で単テナント切替する時だけ設定。
# STUDIO_TENANT=niqostudio
